  "keyFeatures": [
    "RESTful WhatsApp API with multi-device support",
    "Multiple concurrent sessions and users",
    "Webhook notifications with HMAC security",
    "S3-compatible storage for media files",
    "Send text, image, audio, video, document, sticker, location, contact, and poll messages",
    "Group management (create, delete, list, update)",
    "User management with admin endpoints",
    "RabbitMQ integration for event distribution",
    "Docker and Docker Compose support",
    "PostgreSQL and SQLite database support"
  ],
  "publicApiSurface": [
    "POST /session/connect - Connect to WhatsApp",
    "POST /session/disconnect - Disconnect from WhatsApp",
    "POST /session/logout - Logout from WhatsApp",
    "GET /session/status - Get connection status",
    "GET /session/qr - Get QR code for scanning",
    "POST /chat/send/text - Send text message",
    "POST /chat/send/image - Send image message",
    "POST /chat/send/audio - Send audio message",
    "POST /chat/send/video - Send video message",
    "POST /chat/send/document - Send document",
    "POST /chat/send/sticker - Send sticker",
    "POST /chat/send/location - Send location",
    "POST /chat/send/contact - Send contact",
    "POST /chat/send/poll - Send poll",
    "POST /chat/presence - Set chat presence",
    "POST /chat/markread - Mark messages as read",
    "POST /chat/react - React to message",
    "POST /user/info - Get user information",
    "POST /user/check - Check if users are on WhatsApp",
    "POST /user/avatar - Get user avatar",
    "GET /user/contacts - Get all contacts",
    "POST /group/create - Create group",
    "GET /group/list - List groups",
    "GET /group/info - Get group information",
    "GET /group/invitelink - Get group invite link",
    "POST /group/photo - Set group photo",
    "POST /group/name - Set group name",
    "POST /webhook - Configure webhook",
    "GET /webhook - Get webhook configuration",
    "DELETE /webhook - Delete webhook",
    "GET /admin/users - List all users",
    "POST /admin/users - Create user",
    "DELETE /admin/users/{id} - Delete user"
  ]
}
